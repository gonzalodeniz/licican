# ============================================================
# Configuracion general de la aplicacion
# ===========================================================
GITHUB_PAT="github_pat_xxxxxx"
HOST=127.0.0.1
PORT=8000
BASE_PATH=/licican

# ============================================================
# Configuracion compartida de la BBDD integrada
# ============================================================

DB_HOST=localhost
DB_PORT=15432
DB_NAME=licitaciones
DB_USER=licitaciones_admin
DB_PASSWORD=xxxxxx

# ============================================================
# Filtros de importacion
# ============================================================

# Prefijo de códigos NUTS (Nomenclatura de Unidades Territoriales Estadísticas) para filtrar geográficamente.
# ES7 corresponde a la Comunidad Autónoma de Canarias (incluye ES703 Las Palmas, ES709 Tenerife, etc.)
FILTRO_NUTS_PREFIXES=ES7

# Palabras clave para detectar licitaciones de Canarias en la jerarquía orgánica (ParentLocatedParty)
# y en el campo CountrySubentity, como respaldo cuando no hay código NUTS disponible.
FILTRO_GEO_KEYWORDS=canarias

# Prefijos de códigos CPV (Vocabulario Común de Contratos Públicos) para filtrar por tipo de contratación.
# 72 = Servicios TI (consultoría, desarrollo, soporte, mantenimiento de software)
# 48 = Paquetes de software y sistemas de información
# 302 = Equipos y material informático (hardware)
FILTRO_CPV_PREFIXES=72,48,302


# ============================================================
# Inicio de sesion
# ============================================================

# Si se activa el login automatico, se inicia sesion con el superadmin al iniciar la aplicacion
LOGIN_AUTOMATICO=true

# Si se activa el login con superadmin, se permite iniciar sesion con el usuario superadmin. 
# Debe estar activado para que el login automatico funcione.
LOGIN_SUPERADMIN_ENABLED=true

# Credenciales del superadmin. Si el login con superadmin esta activado, se pueden usar estas credenciales para iniciar sesion.
LOGIN_SUPERADMIN_NAME=admin
LOGIN_SUPERADMIN_PASS=admin123

