# ============================================================
# Variables de entorno para postgres-licitaciones
# Copiar este fichero a .env y ajustar los valores
# ============================================================

# Contraseña del usuario administrador de PostgreSQL
POSTGRES_PASSWORD=Lic1t4c10n3s_2026!

# Puerto externo para acceder a PostgreSQL
POSTGRES_PORT=5432

# ============================================================
# Filtros de importación (usados por importar_licitaciones.py)
# ============================================================

# Prefijos NUTS para el filtro geográfico (separados por comas)
# ES7 = Canarias (incluye ES70, ES703, ES705, ES706, ES707, ES709, etc.)
FILTRO_NUTS_PREFIXES=ES7

# Palabras clave para buscar en la jerarquía ParentLocatedParty
# y en CountrySubentity (separadas por comas, case-insensitive)
FILTRO_GEO_KEYWORDS=canarias

# Prefijos CPV para el filtro de tipo de contrato (separados por comas)
# 72 = Servicios TI, 48 = Software, 302 = Equipos informáticos
FILTRO_CPV_PREFIXES=72,48,302
