# ============================================================
# Variables de entorno para importar_licitaciones.py
# Copiar este fichero a .env y ajustar los valores
# ============================================================

# Configuracion de conexion a PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=licitaciones
DB_USER=licitaciones_admin
DB_PASSWORD=xxxxxx

# ============================================================
# Filtros de importacion (usados por importar_licitaciones.py)
# ============================================================

# Prefijos NUTS para el filtro geografico (separados por comas)
# ES7 = Canarias (incluye ES70, ES703, ES705, ES706, ES707, ES709, etc.)
FILTRO_NUTS_PREFIXES=ES7

# Palabras clave para buscar en la jerarquia ParentLocatedParty
# y en CountrySubentity (separadas por comas, case-insensitive)
FILTRO_GEO_KEYWORDS=canarias

# Prefijos CPV para el filtro de tipo de contrato (separados por comas)
# 72 = Servicios TI, 48 = Software, 302 = Equipos informaticos
FILTRO_CPV_PREFIXES=72,48,302
